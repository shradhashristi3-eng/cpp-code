#include <iostream>
#include <vector>
using namespace std;

int linearSearch(const vector<int>& arr, int target)
{
    for(int i = 0; i < arr.size(); i++)
    {
        if(arr[i] == target)
        {
            return i;
        }
    }
    return -1;
}

int main()
{
    vector<int> arr = {64, 34, 25, 12, 22, 11, 90};
    int target = 22;

    int pos = linearSearch(arr, target);

    if(pos != -1)
    {
        cout << "Found " << target << " at index " << pos << endl;
    }
    else
    {
        cout << "Target not found" << endl;
    }

    return 0;
}
