#include <iostream>
using namespace std;
#define MAX 10 //capital letter with no=
class Stack
{
    int arr[MAX];//private
    int top;
    public:
    Stack() : top(-1){}
    void push (int x)
    {
        if(top == MAX-1)
        {
            cout<<"Stack overflow!\n";
            return;
        }//end of if block
        top = top+1;
        arr[top] =x;
    }//end of push()
    void pop()//delete
    {
        if(top == -1)
        {
            cout<<"Stack underflow!\n";
            return;
        }//end of if block
        arr[top] = -1 ;
        top = top - 1;
    }//end of pop()
    int peek()
    {
        if(top==-1)
        {
            cout<<"Stack empty\n";
            return -1;
        }//end of if block
        return arr[top];
    }//end of top()
    bool isEmpty()
    {
        return (top  == -1);
    }//end of isEmpty
    int size()
    {
        return top +1;
    }//end of size()
};//end of class Stack
int main()
{
    Stack s;
    s.push(10);    s.push(20);
    s.push(30);     s.push(40);
    cout<<"Top: "<< s.peek() <<endl;
    s.pop();
    cout<<"After pop,Top: "<< s.peek() <<endl;
    cout<<"size : "<< s.size() <<endl;
    
}//end of main()


