#include <iostream>
#include <vector>
using namespace std;
void bubbleSort(vector<int>& arr)
{
    int n = arr.size();
    for(int i = 0; i<n-1 ;i++)
    {    bool swapped = false;
        for(int pos = 0 ; pos<n-i-1 ; pos++ )
        {
            if(arr[pos] > arr[pos+1])
            {
                swap(arr[pos], arr[pos+1]);
                swapped = true;
            }//end of if block
        }// end of inner for loop
        if(swapped == false)
        {
            break;
        }//end of if block
    }//end of for loop
}// end of bubble Sort
int main()
{
    vector<int> data = {2,3,5,8,12,4,1};
    bubbleSort(data); 
    cout<<"Sorted: ";
    for(int x : data)
    {
        cout<< x << "  ";
    }
}//end of main()
