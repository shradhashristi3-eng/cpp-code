#include <iostream>
#include <vector>
using namespace std;

int binarySearchRec(const vector<int> &arr, int low, int high, int target)
{
    if(low > high)
    {
        return -1;
    }

    int mid = low + ((high - low) / 2);

    if(arr[mid] == target)
    {
        return mid;
    }

    if(target < arr[mid])
    {
        return binarySearchRec(arr, low, mid - 1, target);
    }

    return binarySearchRec(arr, mid + 1, high, target);
}

int main()
{
    vector<int> arr = {2,5,6,8,9,10,12,15,19,22};

    int n = arr.size();

    cout << binarySearchRec(arr, 0, n - 1, 12) << endl;
    cout << binarySearchRec(arr, 0, n - 1, 7) << endl;
    cout << binarySearchRec(arr, 0, n - 1, 22) << endl;

    return 0;
}
